# StaffPick — environment variables
#
# Copy to .env.local for local dev. Production secrets are injected by the
# host (Railway / Azure). Never commit a populated .env file.

# ─── Database ─────────────────────────────────────────────────────────────────
# Azure SQL connection string (sqlserver:// format consumed by @prisma/adapter-mssql).
# Local dev: Azure SQL Edge container, see docs/architecture.md and README.md.
# Prod: Azure SQL Database (Ed provisions).
DATABASE_URL="sqlserver://localhost:1433;database=staffpick;user=sa;password=ChangeMe_StrongPwd_123;encrypt=true;trustServerCertificate=true"

# ─── Auth (NextAuth v5 beta) ──────────────────────────────────────────────────
# `openssl rand -base64 32` for both.
NEXTAUTH_SECRET=""
AUTH_SECRET=""
# Public URL of the app. Local: http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="StaffPick <noreply@staffpick.local>"

# ─── Azure Blob Storage (Phase 4+ — signature uploads, file attachments) ──────
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="staffpick-attachments"

# ─── App config ───────────────────────────────────────────────────────────────
NODE_ENV="development"
# Comma-separated origins for webform CORS / CSRF tightening.
ALLOWED_ORIGINS="http://localhost:3000"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL="debug"   # trace | debug | info | warn | error | fatal

# ─── Stubs (Phase 1+; values not used yet) ────────────────────────────────────
# TheraHealth EMR — stubbed; routes log intent only.
THERAHEALTH_API_BASE=""
THERAHEALTH_API_KEY=""
# SMS — Twilio integration deferred.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── Rate limiting (auth endpoints) ───────────────────────────────────────────
# Optional Upstash Redis for distributed rate limiting; falls back to in-memory
# when unset. Required for prod, optional local.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
