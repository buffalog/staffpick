# StaffPick — production environment variables (Railway `app` service).
# Set these in the Railway dashboard: app service -> Variables.
# Do NOT commit a filled-in copy. `.env*` is gitignored except this template.

# ── Database ──────────────────────────────────────────────────────────────────
# Points at the Railway `db` service over the PRIVATE network.
# Replace <SA_PASSWORD> with the MSSQL_SA_PASSWORD you set on the db service.
# If you named the db service something other than "db", change the host.
DATABASE_URL="sqlserver://db.railway.internal:1433;database=staffpick;user=sa;password=<SA_PASSWORD>;encrypt=true;trustServerCertificate=true"

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# openssl rand -base64 32   (use the SAME value for both)
AUTH_SECRET="<generate>"
NEXTAUTH_SECRET="<generate>"
# The Railway-assigned public domain, https. Set AFTER you generate the domain.
AUTH_URL="https://<app>.up.railway.app"
NEXTAUTH_URL="https://<app>.up.railway.app"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. Without a key, emails (Provider OTP codes, notifications,
# invoices) fall back to structured logs — visible via `railway logs`.
RESEND_API_KEY=""
RESEND_FROM="StaffPick <noreply@staffpick.local>"

# ── Cloudflare Turnstile (public webform CAPTCHA) ─────────────────────────────
# Cloudflare's documented test keys always pass on any domain — fine for a
# demo. For a real public form, mint site-specific keys at
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── App config ────────────────────────────────────────────────────────────────
NODE_ENV="production"
ALLOWED_ORIGINS="https://<app>.up.railway.app"
LOG_LEVEL="info"
