<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         displayDetailsOnTestsThatTriggerErrors="true"

>
    <!-- ExampleTest (an empty Laravel skeleton stub) and FeatureTest (our base class) both
         match the *Test.php suffix but declare no test methods, so PHPUnit raises
         "No tests found in class". PHPUnit 11 defaults failOnPhpunitWarning to TRUE, so those
         two warnings alone exit 1 — a fully passing suite still reported a red build. Exclude
         the non-test files rather than switching the flag off; it's worth keeping, it's what
         catches things like a misnamed test method. -->
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
            <exclude>./tests/Unit/ExampleTest.php</exclude>
        </testsuite>
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
            <exclude>./tests/Feature/FeatureTest.php</exclude>
        </testsuite>
    </testsuites>
    <!-- Dead SaaSykit billing boilerplate (checkout/plans). StaffPick ships none of it, so
         these are excluded from the default run. Run them ad hoc by passing the group
         explicitly to phpunit. -->
    <groups>
        <exclude>
            <group>saasykit-unused</group>
        </exclude>
    </groups>
    <source>
        <include>
            <directory suffix=".php">./app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <!-- Exercise the covered geocoding path (Azure, with faked HTTP) rather than the
             fail-closed no-op, so the on-save geocoding tests still assert real resolution. -->
        <env name="GEOCODING_DRIVER" value="azure"/>
        <env name="AZURE_MAPS_KEY" value="test-key"/>
    </php>
</phpunit>
